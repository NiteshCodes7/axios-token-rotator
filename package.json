{
  "name": "axios-token-rotator",
  "version": "1.1.1",
  "description": "Zero-dependency axios interceptor for automatic JWT token rotation with race-condition safety and full TypeScript support",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "jest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "axios",
    "interceptor",
    "token",
    "refresh",
    "jwt",
    "auth",
    "token-rotation",
    "401",
    "authentication",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "axios": ">=1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/mocha": "^10.0.10",
    "axios": "^1.6.8",
    "axios-mock-adapter": "^1.22.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NiteshCodes7/axios-token-rotator"
  },
  "homepage": "https://github.com/NiteshCodes7/axios-token-rotator#readme",
  "bugs": {
    "url": "https://github.com/NiteshCodes7/axios-token-rotator/issues"
  }
}
